# DEV environment variables – copy to .env.dev and fill in real values.
# Usage: cp .env.dev.example .env.dev && source .env.dev

# ---- Database ----
DB_URL=jdbc:postgresql://localhost:5432/authdb_dev
DB_USER=authuser
DB_PASSWORD=devpass

# ---- JWT (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem) ----
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_DEV_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_DEV_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"

# ---- Mail (use MailHog or Mailtrap in dev) ----
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# ---- Spring ----
SPRING_PROFILES_ACTIVE=dev
