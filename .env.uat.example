# UAT environment variables – copy to .env.uat and fill in real values.
# These should be populated by your CI/CD pipeline, NOT committed to source control.

# ---- Database ----
DB_URL_UAT=jdbc:postgresql://uat-postgres:5432/authdb_uat
DB_USER_UAT=CHANGE_ME
DB_PASSWORD_UAT=CHANGE_ME

# ---- JWT ----
JWT_PRIVATE_KEY_UAT="CHANGE_ME"
JWT_PUBLIC_KEY_UAT="CHANGE_ME"

# ---- TLS ----
SSL_KEYSTORE_PASSWORD_UAT=CHANGE_ME

# ---- Mail ----
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=uat-noreply@example.com
MAIL_PASSWORD=CHANGE_ME

# ---- Spring ----
SPRING_PROFILES_ACTIVE=uat
