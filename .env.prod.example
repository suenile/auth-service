# PROD environment variables – NEVER commit real values.
# Inject via your secret manager (HashiCorp Vault, AWS Secrets Manager, GCP Secret Manager, etc.)
# or via Kubernetes Secrets / CI/CD masked variables.

# ---- Database ----
DB_URL=CHANGE_ME
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# ---- JWT ----
JWT_PRIVATE_KEY=CHANGE_ME
JWT_PUBLIC_KEY=CHANGE_ME

# ---- TLS ----
SSL_KEYSTORE_PASSWORD=CHANGE_ME

# ---- CORS ----
CORS_ALLOWED_ORIGINS=https://app.example.com

# ---- Mail ----
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME

# ---- Spring ----
SPRING_PROFILES_ACTIVE=prod
